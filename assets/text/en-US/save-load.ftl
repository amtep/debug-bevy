save-error =
    .title = Save Error
    .body = We were unable to save your game.
  The exact error message can be found in the game logs.
  If you tab out of the game, you can try to fix it and try again.
  We apologize for the inconvenience.
    .confirm = Ok

load-scan-error =
    .title = Load Error
    .body = We were unable to find your saved games.
  The exact error message can be found in the game logs.
  We apologize for the inconvenience.
    .confirm = Ok

load-error =
    .title = Load Error
    .body = We were unable to load your saved game.
  The exact error message can be found in the game logs.
  You can try to fix it, or start a new game.
  We apologize for the loss.
    .confirm = Ok

load-game =
    .title = Select Saved Game
    .confirm = Load
    .confirm-tooltip = Select a saved game first!
	.cancel = Back

saved-game-date = last played { DATETIME($date, dateStyle: "medium", timeStyle: "short") }
