save-error-title = Save Error
save-error-body = We were unable to save your game.
  The exact error message can be found in the game logs.
  If you tab out of the game, you can try to fix it and try again.
  We apologize for the inconvenience.

load-scan-error-title = Load Error
load-scan-error-body = We were unable to find your saved games.
  The exact error message can be found in the game logs.
  We apologize for the inconvenience.

load-error-title = Load Error
load-error-body = We were unable to load your saved game.
  The exact error message can be found in the game logs.
  You can try to fix it, or start a new game.
  We apologize for the loss.

load-game-title = Select Saved Game
load-game-confirm = Load
load-game-confirm-tooltip = select a saved game first!

saved-game-date = last played { DATETIME($date, dateStyle: "medium", timeStyle: "short") }
